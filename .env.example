# Aria environment variables — copy to .env and fill in your values.
# Only configure the sources you actually plan to use.

# === Core ===
MUSIC_DIR=/music
DOWNLOADS_DIR=/downloads
DB_PATH=/data/aria.db
INTERVAL=3600
ARIA_API_KEY=

# === Deezer (downloads via personal ARL cookie) ===
DEEMIX_ARL=

# === Spotify (metadata / search) ===
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# === Discogs (metadata lookup) ===
DISCOGS_TOKEN=

# === Plex (read existing library to seed recommendations) ===
PLEX_URL=
PLEX_TOKEN=

# === Qobuz / Spotiflac (hi-res search) ===
QOBUZ_TOKEN=

# === AcoustID (fingerprint matching) ===
ACOUSTID_API_KEY=

# === Soulseek (downloads via slskd daemon) ===
SLSKD_URL=http://slskd:5030
SLSKD_API_KEY=
